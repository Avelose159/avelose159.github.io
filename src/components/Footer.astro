---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Avelose's DevLog. All rights reserved.
</footer>
<style>
	footer {
		padding: 1em 1em 1em 1em;
		background: rgba(28, 28, 28, 1);
		color: white;
		text-align: center;
		position: fixed;
		bottom: 0;
		left: 0;
		width: 100%;
		z-index: 1000;
		margin-top: auto;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
