---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* 전역 여백 제거 */
			:global(html), :global(body) {
				margin: 0;
				padding: 0;
				width: 100%;
				max-width: none !important;
				overflow-x: hidden;
			}
			/* 헤더 투명화 설정 */
			:global(header) {
				position: absolute !important;
				top: 0;
				left: 0;
				width: 100%;
				background: transparent !important;
				box-shadow: none !important;
				z-index: 100;
			}
			:global(header h2 a), :global(header nav a), :global(header .social-links a) {
				color: white !important;
			}
			.hero-section {
				position: relative;
				width: 100%;
				height: 100vh;
				background-color: #000;
				z-index: 0;
			}
			.hero-bg {
				width: 100%;
				height: 100%;
				object-fit: cover;
				opacity: 0.6;
				border-radius: 0 !important;
				display: block;
			}
			.hero-content {
				position: absolute;
				inset: 0;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				z-index: 10;
				text-align: center;
				color: white;
			}
			.motto {
				font-size: 4rem;
				font-weight: 900;
				line-height: 1.1;
				letter-spacing: -0.05em;
				color: white;
			}
			@media (min-width: 768px) {
				.motto { font-size: 7rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<section class="hero-section">
			<img src="/bg-hero.jpg" alt="배경 이미지" class="hero-bg" />
			<div class="hero-content">
				<h1 class="motto">Don't Think<br/>Just Do.</h1>
				<p style="margin-top: 1.5rem; font-size: 1.25rem; opacity: 0.8; letter-spacing: 0.2em;">
					GAME DEVELOPER • AVELOSE
				</p>
			</div>
		</section>
		<Footer />
	</body>
</html>