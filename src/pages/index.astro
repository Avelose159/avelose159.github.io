---
// 1. 필요한 핵심 컴포넌트만 직접 가져옵니다.
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* 배경 이미지를 위한 스타일 */
			:global(header) {
				position: absolute !important;
				top: 0;
				left: 0;
				width: 100%;
				background: transparent !important;
				box-shadow: none !important;
				z-index: 100;
			}
			:global(header h2 a), :global(header nav a), :global(header .social-links a) {
				color: white !important;
			}
			.hero-section {
				position: relative;
				width: 100%;
				overflow: hidden;
				background-color: #000;
			}
			.hero-bg {
				width: 100%;
				height: auto;
				display: block;
				opacity: 0.6; /* 글자가 잘 보이도록 배경을 어둡게 합니다. */
			}
			.hero-content {
				position: absolute;
				inset: 0;
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
				z-index: 10;
				text-align: center;
				color: white;
			}
			.motto {
				font-size: 4rem;
				font-weight: 900;
				line-height: 1.1;
				letter-spacing: -0.05em;
				color: white;
			}
			@media (min-width: 768px) {
				.motto { font-size: 7rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<section class="hero-section">
			<img src="/bg-hero.jpg" alt="배경 이미지" class="hero-bg" />
			
			<div class="hero-content">
				<h1 class="motto">
					Don't Think<br/>Just Do.
				</h1>
				<p style="margin-top: 1.5rem; font-size: 1.25rem; opacity: 0.8; letter-spacing: 0.2em; color: white;">
					GAME DEVELOPER • AVELOSE159
				</p>
			</div>
		</section>
		<Footer />
	</body>
</html>