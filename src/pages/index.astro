---
// 1. 필요한 데이터와 컴포넌트 임포트
import { getCollection } from 'astro:content';
import Layout from '../layouts/BaseLayout.astro'; // 레이아웃 파일명을 확인하세요! (Layout.astro 일 수도 있음)
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// 2. 게시글 데이터를 가져와서 에러 방지 (toISOString 에러 해결책)
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main>
		<section class="relative w-full h-screen flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 z-0">
				<img 
					src="/bg-hero.jpg" 
					alt="Background" 
					class="w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-black/60"></div>
			</div>

			<div class="relative z-10 text-center text-white px-4">
				<h1 class="text-5xl md:text-8xl font-black tracking-tighter drop-shadow-2xl animate-fade-in">
					Don't Think <br class="md:hidden" /> Just Do.
				</h1>
				<p class="mt-6 text-lg md:text-2xl font-light text-gray-300 tracking-widest opacity-80">
					GAME DEVELOPER • AVELOSE159
				</p>
			</div>
		</section>

		<section class="max-w-4xl mx-auto px-6 py-20">
			<h2 class="text-3xl font-bold mb-10 text-center">Latest Logs</h2>
			<ul class="grid gap-8">
				{
					posts.slice(0, 3).map((post) => (
						<li class="border-b border-gray-200 pb-6">
							<a href={`/blog/${post.slug}/`} class="group">
								<span class="text-sm text-gray-500">{post.data.pubDate.toLocaleDateString()}</span>
								<h3 class="text-xl font-bold group-hover:text-blue-600 transition-colors">
									{post.data.title}
								</h3>
								<p class="text-gray-600 mt-2 line-clamp-2">{post.data.description}</p>
							</a>
						</li>
					))
				}
			</ul>
		</section>
	</main>
</Layout>

<style>
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(30px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in {
		animation: fadeIn 1.2s ease-out forwards;
	}
</style>