---
// 1. 프런트매터: 자바스크립트 로직 구역
import Layout from '../layouts/Layout.astro'; // 템플릿에 따라 'BaseLayout'일 수 있으니 확인하세요!
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main>
		<section class="relative w-full h-screen flex items-center justify-center overflow-hidden">
			
			<div class="absolute inset-0 z-0">
				<img 
					src="/bg-hero.jpg" 
					alt="Background" 
					class="w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-black/50"></div>
			</div>

			<div class="relative z-10 text-center text-white px-4">
				<h1 class="text-5xl md:text-8xl font-black tracking-tighter drop-shadow-2xl animate-fade-in">
					Don't Think <br class="md:hidden" /> Just Do.
				</h1>
				<p class="mt-6 text-lg md:text-2xl font-light text-gray-300 tracking-widest opacity-80">
					GAME DEVELOPER • AVELOSE159
				</p>
				
				<div class="mt-12 animate-bounce">
					<span class="text-sm uppercase tracking-widest text-gray-400">Scroll Down</span>
				</div>
			</div>
		</section>

		<div class="max-w-4xl mx-auto px-6 py-20">
			<h2 class="text-3xl font-bold mb-8">Latest Log</h2>
			<p class="text-gray-600">
				현재 개발 중인 <strong>Starkeeper</strong>의 제작 일지와 기술적인 고민들을 기록합니다.
			</p>
			</div>
	</main>
</Layout>

<style>
	/* 간단한 애니메이션 추가 */
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in {
		animation: fadeIn 1.5s ease-out forwards;
	}
</style>