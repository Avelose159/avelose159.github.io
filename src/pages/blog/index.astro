---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 카테고리 목록 추출
const categories = ['STAR KEEPER', 'MENTIST', 'CODING'];
const categoryCounts = categories.reduce((acc, cat) => {
	acc[cat] = posts.filter((p) => p.data.category === cat).length;
	return acc;
}, {} as Record<string, number>);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`${SITE_TITLE} | Blog`} description={SITE_DESCRIPTION} />
		<style>
			:global(html), :global(body) {
				margin: 0; padding: 0; width: 100%; min-height: 100%;
				background: #000 url('/space.jpg') center/cover no-repeat fixed;
				color: white;
			}
			:global(header) {
				background: #000 !important;
				box-shadow: 0 2px 8px rgba(255, 255, 255, 0.05) !important;
			}
			:global(header h2 a), :global(header nav a) {
				color: #fff !important;
			}
			main {
				width: 100%;
				padding: 8rem 1rem 5rem 1rem; /* 위쪽 여백(padding-top)을 5rem에서 8rem으로 늘림 */
				display: flex;
				justify-content: center;
				gap: 2rem;
				max-width: 1200px;
				margin: 0 auto;
			}
			/* 좌측 카테고리 사이드바 */
			.sidebar {
				width: 200px;
				flex-shrink: 0;
				position: sticky;
				top: 8rem; /* main의 padding-top과 맞춰줌 */
				align-self: flex-start;
			}
			.sidebar h3 {
				font-size: 1.1rem;
				font-weight: 700;
				margin: 0 0 1rem 0;
				color: rgba(255, 255, 255, 0.9);
				letter-spacing: 0.05em;
			}
			.sidebar ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.sidebar ul li button {
				width: 100%;
				text-align: left;
				background: rgba(255, 255, 255, 0.05);
				border: 1px solid rgba(255, 255, 255, 0.1);
				color: rgba(255, 255, 255, 0.7);
				padding: 0.6rem 1rem;
				border-radius: 8px;
				cursor: pointer;
				font-size: 0.9rem;
				transition: all 0.2s ease;
			}
			.sidebar ul li button:hover {
				background: rgba(255, 255, 255, 0.12);
				color: #fff;
			}
			.sidebar ul li button.active {
				background: rgba(255, 255, 255, 0.18);
				color: #fff;
				border-color: rgba(255, 255, 255, 0.3);
				font-weight: 600;
			}
			/* 우측 포스트 목록 */
			.posts {
				flex: 1;
				max-width: 800px;
			}
			.posts ul {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.posts ul li a { 
				display: block; 
				text-decoration: none; 
				padding: 1rem;
				border: 1px solid rgba(255, 255, 255, 0.15); /* 새로 추가한 테두리 */
				border-radius: 16px;
				background: rgba(0, 0, 0, 0.3); /* 살짝 어두운 배경 */
				transition: all 0.3s ease;
			}
			.posts ul li a:hover {
				background: rgba(255, 255, 255, 0.05);
				border-color: rgba(255, 255, 255, 0.4);
				transform: translateY(-4px);
			}
			.posts ul li img {
				width: 100%;
				margin-bottom: 1rem;
				border-radius: 12px;
				border: 1px solid rgba(255, 255, 255, 0.1);
				transition: all 0.4s ease;
			}
			.title { margin: 0.5rem 0; color: #fff; font-size: 1.3rem; font-weight: 700; }
			.date { font-size: 0.85rem; color: rgba(255, 255, 255, 0.5); }
			.category-tag {
				display: inline-block;
				font-size: 0.75rem;
				padding: 0.2rem 0.6rem;
				background: rgba(255, 255, 255, 0.1);
				border-radius: 4px;
				color: rgba(255, 255, 255, 0.6);
				margin-bottom: 0.3rem;
			}
			@media (max-width: 768px) {
				main { flex-direction: column; padding-top: 5rem; }
				.sidebar {
					width: 100%;
					position: static;
				}
				.sidebar ul {
					flex-direction: row;
					flex-wrap: wrap;
					gap: 0.5rem;
				}
				.sidebar ul li button { width: auto; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<aside class="sidebar">
				<h3>📂 카테고리</h3>
				<ul>
					<li><button class="category-btn active" data-category="all">전체 ({posts.length})</button></li>
					{categories.map((cat) => (
						<li><button class="category-btn" data-category={cat}>{cat} ({categoryCounts[cat]})</button></li>
					))}
				</ul>
			</aside>
			<div class="posts">
				<ul>
					{
						posts.map((post) => (
							<li data-category={post.data.category}>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<img width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<span class="category-tag">{post.data.category}</span>
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
									<h4 class="title">{post.data.title}</h4>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</main>
		<Footer />

		<script is:inline>
			(function() {
				const buttons = document.querySelectorAll('.category-btn');
				const items = document.querySelectorAll('.posts ul li');

				buttons.forEach(function(btn) {
					btn.addEventListener('click', function() {
						buttons.forEach(function(b) { b.classList.remove('active'); });
						btn.classList.add('active');

						const category = btn.getAttribute('data-category');

						items.forEach(function(item) {
							if (category === 'all' || item.getAttribute('data-category') === category) {
								item.style.display = '';
							} else {
								item.style.display = 'none';
							}
						});
						
						// 부드럽게 화면 맨 위로 스크롤
						window.scrollTo({ top: 0, behavior: 'smooth' });
					});
				});
			})();
		</script>
	</body>
</html>