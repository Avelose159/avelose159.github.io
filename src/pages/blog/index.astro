---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 카테고리 목록 추출
const categories = ['STAR KEEPER', 'MENTIST', 'CODING', 'MATH'];
const categoryCounts = categories.reduce((acc, cat) => {
	acc[cat] = posts.filter((p) => p.data.category === cat).length;
	return acc;
}, {} as Record<string, number>);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`${SITE_TITLE} | Blog`} description={SITE_DESCRIPTION} />
		<style>
			:global(html), :global(body) {
				margin: 0; padding: 0; width: 100%; min-height: 100%;
				background: #000 url('/space.jpg') center/cover no-repeat fixed;
				color: white;
			}
			/* Custom scrollbar to prevent ugly white bars on Windows */
			:global(::-webkit-scrollbar) {
				width: 10px;
				background: transparent;
			}
			:global(::-webkit-scrollbar-track) {
				background: rgba(0, 0, 0, 0.3);
			}
			:global(::-webkit-scrollbar-thumb) {
				background: rgba(255, 255, 255, 0.2);
				border-radius: 5px;
			}
			:global(::-webkit-scrollbar-thumb:hover) {
				background: rgba(255, 255, 255, 0.4);
			}
			:global(header) {
				background: #000 !important;
				box-shadow: 0 2px 8px rgba(255, 255, 255, 0.05) !important;
			}
			:global(header h2 a), :global(header nav a) {
				color: #fff !important;
			}
			main {
				width: 100%;
				padding: 8rem 1rem 5rem 1rem; /* 위쪽 여백(padding-top)을 5rem에서 8rem으로 늘림 */
				display: flex;
				justify-content: center;
				gap: 2rem;
				max-width: 1200px;
				margin: 0 auto;
			}
			/* 좌측 카테고리 사이드바 */
			.sidebar {
				width: 200px;
				flex-shrink: 0;
				position: sticky;
				top: 8rem; /* main의 padding-top과 맞춰줌 */
				align-self: flex-start;
			}
			.sidebar h3 {
				font-size: 1.1rem;
				font-weight: 700;
				margin: 0 0 1rem 0;
				color: rgba(255, 255, 255, 0.9);
				letter-spacing: 0.05em;
			}
			.sidebar ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.sidebar ul li button {
				width: 100%;
				text-align: left;
				background: rgba(255, 255, 255, 0.05);
				border: 1px solid rgba(255, 255, 255, 0.1);
				color: rgba(255, 255, 255, 0.7);
				padding: 0.6rem 1rem;
				border-radius: 8px;
				cursor: pointer;
				font-size: 0.9rem;
				transition: all 0.2s ease;
			}
			.sidebar ul li button:hover {
				background: rgba(255, 255, 255, 0.12);
				color: #fff;
			}
			.sidebar ul li button.active {
				background: rgba(255, 255, 255, 0.18);
				color: #fff;
				border-color: rgba(255, 255, 255, 0.3);
				font-weight: 600;
			}
			/* 우측 포스트 목록 */
			.posts {
				flex: 1;
				max-width: 1000px;
			}
			.posts ul {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.posts ul li .post-header { 
				display: block; 
				text-decoration: none; 
				padding: 1rem;
				border: 1px solid rgba(255, 255, 255, 0.15); /* 새로 추가한 테두리 */
				border-radius: 16px;
				background: rgba(0, 0, 0, 0.3); /* 살짝 어두운 배경 */
				transition: all 0.3s ease;
                cursor: pointer;
			}
			.posts ul li .post-header:hover {
				background: rgba(255, 255, 255, 0.05);
				border-color: rgba(255, 255, 255, 0.4);
				transform: translateY(-4px);
			}
			.posts ul li img {
				width: 100%;
				margin-bottom: 1rem;
				border-radius: 12px;
				border: 1px solid rgba(255, 255, 255, 0.1);
				transition: all 0.4s ease;
			}
            .post-header .title {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin: 0.5rem 0 0 0; 
                color: #fff; 
                font-size: 1.3rem; 
                font-weight: 700;
            }
            .toggle-icon {
                font-size: 0.9rem;
                color: rgba(255,255,255,0.5);
                transition: transform 0.3s ease;
            }
            .post-header.open .toggle-icon {
                transform: rotate(180deg);
            }
            .click-hint {
                font-size: 0.85rem;
                color: rgba(255,255,255,0.3);
                margin-top: 0.5rem;
                display: block;
                transition: color 0.3s ease;
            }
            .post-header:hover .click-hint {
                color: rgba(255,255,255,0.8);
            }
            .post-header.open .click-hint {
                display: none;
            }
			.date { font-size: 0.85rem; color: rgba(255, 255, 255, 0.5); }
			.category-tag {
				display: inline-block;
				font-size: 0.75rem;
				padding: 0.2rem 0.6rem;
				background: rgba(255, 255, 255, 0.1);
				border-radius: 4px;
				color: rgba(255, 255, 255, 0.6);
				margin-bottom: 0.3rem;
			}
            .post-content-container {
                display: none;
                margin-top: 1rem;
                padding: 1.5rem;
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 12px;
                background: rgba(0,0,0,0.5);
                color: #e5e9f0;
            }
            .post-content-container.expanded {
                display: block;
                animation: fadeIn 0.3s ease-out forwards;
            }
            @keyframes fadeIn {
                from { opacity: 0; transform: translateY(-10px); }
                to { opacity: 1; transform: translateY(0); }
            }
            .loading-spinner {
                text-align: center;
                padding: 2rem;
                color: rgba(255,255,255,0.6);
            }
            .loading-spinner::after {
                content: "...";
                animation: ellipsis steps(4,end) 1.5s infinite;
            }
            @keyframes ellipsis {
                0% { content: ""; }
                25% { content: "."; }
                50% { content: ".."; }
                75% { content: "..."; }
                100% { content: ""; }
            }
            .close-article-btn {
                display: block;
                width: 100%;
                margin-top: 2rem;
                padding: 1rem;
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
                color: rgba(255,255,255,0.8);
                border-radius: 8px;
                font-size: 0.95rem;
                cursor: pointer;
                transition: all 0.2s ease;
                text-align: center;
            }
            .close-article-btn:hover {
                background: rgba(255,255,255,0.1);
                border-color: rgba(255,255,255,0.3);
                color: #fff;
            }
			@media (max-width: 768px) {
				main { flex-direction: column; padding-top: 5rem; }
				.sidebar {
					width: 100%;
					position: static;
				}
				.sidebar ul {
					flex-direction: row;
					flex-wrap: wrap;
					gap: 0.5rem;
				}
				.sidebar ul li button { width: auto; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<aside class="sidebar">
				<h3>📂 카테고리</h3>
				<ul>
					{categories.map((cat, index) => (
						<li>
							<button class={`category-btn ${index === 0 ? 'active' : ''}`} data-category={cat}>
								{cat} ({categoryCounts[cat] || 0})
							</button>
						</li>
					))}
				</ul>
			</aside>
			<div class="posts">
				<ul>
					{
						posts.map((post) => (
							<li data-category={post.data.category} style={post.data.category !== categories[0] ? 'display: none;' : ''}>
								<div class="post-header" data-href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<img width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<span class="category-tag">{post.data.category}</span>
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
									<h4 class="title">
                                        {post.data.title}
                                        <span class="toggle-icon">▼</span>
                                    </h4>
                                    <span class="click-hint">클릭하여 본문 펼쳐보기</span>
								</div>
                                <div class="post-content-container"></div>
							</li>
						))
					}
				</ul>
			</div>
		</main>
		<Footer />

		<script is:inline>
			(function() {
				const buttons = document.querySelectorAll('.category-btn');
				const items = document.querySelectorAll('.posts ul li');

				buttons.forEach(function(btn) {
					btn.addEventListener('click', function() {
						buttons.forEach(function(b) { b.classList.remove('active'); });
						btn.classList.add('active');

						const category = btn.getAttribute('data-category');

						items.forEach(function(item) {
							if (item.getAttribute('data-category') === category) {
								item.style.display = '';
							} else {
								item.style.display = 'none';
							}
						});
						
						// 부드럽게 화면 맨 위로 스크롤
						window.scrollTo({ top: 0, behavior: 'smooth' });
					});
				});

                const postHeaders = document.querySelectorAll('.post-header');
                postHeaders.forEach(function(header) {
                    header.addEventListener('click', async function(e) {
                        e.preventDefault();
                        const contentContainer = header.nextElementSibling;
                        if (!contentContainer || !contentContainer.classList.contains('post-content-container')) return;

                        const isExpanded = contentContainer.classList.contains('expanded');
                        
                        // 클릭 중복 방지: 로딩중이면 무시
                        if (header.classList.contains('loading')) return;

                        // 다른 열린 아코디언들을 닫는 옵션
                        document.querySelectorAll('.post-content-container.expanded').forEach(c => {
                            if (c !== contentContainer) {
                                c.classList.remove('expanded');
                                if (c.previousElementSibling && c.previousElementSibling.classList.contains('post-header')) {
                                    c.previousElementSibling.classList.remove('open');
                                }
                            }
                        });

                        if (!isExpanded) {
                            // 열기 동작
                            contentContainer.classList.add('expanded');
                            header.classList.add('open');
                            
                            // 처음 열린 경우에만 데이터를 가져옴
                            if (contentContainer.innerHTML.trim() === '') {
                                header.classList.add('loading');
                                contentContainer.innerHTML = '<div class="loading-spinner">내용을 불러오는 중입니다</div>';
                                const url = header.getAttribute('data-href');
                                
                                try {
                                    const res = await fetch(url);
                                    if (!res.ok) throw new Error('Network response was not ok');
                                    const htmlText = await res.text();
                                    
                                    const parser = new DOMParser();
                                    const doc = parser.parseFromString(htmlText, 'text/html');
                                    const proseNode = doc.querySelector('.prose'); // 원본 페이지 컨텐츠 영역 추출
                                    
                                    if (proseNode) {
                                        // 상세보기 페이지에 있던 제목 등은 리스트에서 이미 보여주므로 삭제
                                        const titleNode = proseNode.querySelector('.title');
                                        if (titleNode) titleNode.remove();

                                        contentContainer.innerHTML = ''; 
                                        
                                        // 테마를 일치시키기 위해 가져온 페이지 body에 있는 class를 현재 컨테이너로 복사
                                        // 이때 expanded 속성이 유실되지 않게 합칩니다.
                                        contentContainer.className = `post-content-container expanded base-theme ${doc.body.className}`;
                                        contentContainer.appendChild(proseNode);

                                        // 하단 접기 버튼 추가
                                        const closeBtn = document.createElement('button');
                                        closeBtn.className = 'close-article-btn';
                                        closeBtn.innerHTML = '▲ 본문 접기';
                                        closeBtn.addEventListener('click', (ev) => {
                                            ev.stopPropagation(); // 이벤트 버블링 방지
                                            contentContainer.classList.remove('expanded');
                                            header.classList.remove('open');
                                            // 닫을 때 포스트 헤더 위치로 스크롤 이동
                                            header.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                        });
                                        contentContainer.appendChild(closeBtn);

                                    } else {
                                        contentContainer.innerHTML = '<p>본문을 찾을 수 없습니다.</p>';
                                    }
                                } catch (err) {
                                    console.error(err);
                                    contentContainer.innerHTML = '<p>본문을 가져오는 중 오류가 발생했습니다.</p>';
                                } finally {
                                    header.classList.remove('loading');
                                    
                                    // 로딩 중 아코디언이 닫혔었다면(유저 변심) 다시 숨김
                                    if (!header.classList.contains('open')) {
                                        contentContainer.classList.remove('expanded');
                                    }
                                }
                            }
                            
                            setTimeout(() => {
                                header.scrollIntoView({ behavior: 'smooth', block: 'start' });
                            }, 100);
                        } else {
                            // 닫기 동작
                            contentContainer.classList.remove('expanded');
                            header.classList.remove('open');
                        }
                    });
                });
			})();
		</script>
	</body>
</html>